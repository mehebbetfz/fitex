# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/fitex

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com
GOOGLE_MOBILE_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com

# ── Apple Sign In ─────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=com.farzaliyev.fitex.service
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----

# ── In-App Purchases ──────────────────────────────────────────────────────────
APPLE_SHARED_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_PLAY_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AWS S3 (optional, for photo uploads) ─────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=fitex-uploads
# AWS_REGION=eu-central-1

# ── Redis (optional, for caching) ────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Email (SMTP for verification codes) ──────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=FitEx <your-email@gmail.com>

# ── App Store Review Demo Account ────────────────────────────────────────────
# Password for the demo reviewer account (POST /auth/demo)
DEMO_PASSWORD=FitExDemo2024!
